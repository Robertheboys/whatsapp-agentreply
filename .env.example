# ════════════════════════════════════════════════════════════
#  AgentKit WhatsApp (Zernio + OpenRouter) — Variables de entorno
#  Copia este archivo como .env y llena tus valores:
#      cp .env.example .env
#  NUNCA subas el archivo .env a GitHub (ya está en .gitignore).
#  El comando /setup-agente puede llenarlo por ti.
# ════════════════════════════════════════════════════════════

# ── OpenRouter (el "cerebro" de IA) ───────────────────────────
# Obtener en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Zernio (proveedor de WhatsApp) ────────────────────────────
# API Key: dashboard de Zernio → API Keys
ZERNIO_API_KEY=
# Secreto para validar la firma del webhook (HMAC-SHA256).
# Genera uno aleatorio, ej: openssl rand -hex 32
ZERNIO_WEBHOOK_SECRET=

# ── Seguridad de endpoints internos ───────────────────────────
# Token que protege /reports y /sale. Genera uno aleatorio.
REPORT_TOKEN=

# ── Anuncios Click-to-WhatsApp + ROAS (opcional) ──────────────
# Pon ENABLE_ADS=true solo si corres anuncios de Meta y quieres
# atribución + conversiones + ROAS.
# NO necesitas token de Meta: con tu cuenta de Meta Ads CONECTADA A ZERNIO,
# el kit obtiene nombre de anuncio y gasto vía la Ads API de Zernio.
ENABLE_ADS=false
# (Opcional) Token de Meta con scope ads_read. SOLO si prefieres ir directo a
# Meta en vez de Zernio (respaldo). Déjalo vacío para usar solo Zernio.
META_ACCESS_TOKEN=
# Versión de la Graph API de Meta (solo aplica si usas META_ACCESS_TOKEN).
META_GRAPH_VERSION=v21.0

# ── Estilo de respuesta (más humano) ──────────────────────────
# Responder en varios "globos" (mensajes) en vez de uno solo, con "escribiendo…".
MULTI_BUBBLE=true
# Máximo de globos por respuesta.
BUBBLE_MAX=4

# ── Servidor ──────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production

# ── Base de datos ─────────────────────────────────────────────
# Por defecto: local (funciona en Windows/Mac/Linux y en la prueba local).
DATABASE_URL=sqlite+aiosqlite:///./data/agente.db
# En producción con Docker/Coolify (volumen montado en /app/data), usa esta en su lugar:
#   DATABASE_URL=sqlite+aiosqlite:////app/data/agente.db
